{
  "name": "parsecraft",
  "version": "0.1.0",
  "description": "Compile-time macro parser combinators with optimized output",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js",
      "require": "./dist/plugin/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc"
  },
  "keywords": [
    "parser",
    "parser-combinators",
    "macro",
    "compile-time",
    "codegen"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "~26.0.0",
    "esbuild": "~0.28.1",
    "tsup": "~8.5.1",
    "typescript": "7.0.1-rc",
    "vite": "~8.0.16",
    "vitest": "~4.1.9"
  },
  "dependencies": {
    "regexp-tree": "~0.1.27",
    "unplugin": "~3.0.0"
  }
}
