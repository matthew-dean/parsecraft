#!/bin/sh
# Pre-commit guards: typecheck, oxlint, and optional perf regression check.
#
# Set SKIP_TYPECHECK=1 or SKIP_LINT=1 to bypass individual guards.
# Set SKIP_PERF_GUARD=1 to bypass the perf guard (e.g. WIP commits).

set -e

if [ "$SKIP_TYPECHECK" != "1" ]; then
  echo "[pre-commit] running tsc…"
  pnpm typecheck
fi

if [ "$SKIP_LINT" != "1" ]; then
  echo "[pre-commit] running oxlint…"
  pnpm lint
fi

if [ "$SKIP_PERF_GUARD" = "1" ]; then
  exit 0
fi

# Limit perf guard to commits that can actually affect compiled output.
CHANGED=$(git diff --cached --name-only)
echo "$CHANGED" | grep -qE '^(src/compiler/|src/combinators/|src/cst/|examples/.*/parser\.ts|bench/parseman-perf\.ts)' || exit 0

echo "[pre-commit] running parseman perf guard (css ratio)…"
node --import tsx/esm bench/perf-guard.ts
status=$?
if [ $status -ne 0 ]; then
  echo "[pre-commit] perf guard failed — commit blocked. Bypass with SKIP_PERF_GUARD=1 if intentional."
fi
exit $status
